<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /eduqr-rebuild/public/

    # Mevcut dosya veya dizin varsa doğrudan ona git
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Aksi takdirde tüm istekleri index.php'ye yönlendir
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>
