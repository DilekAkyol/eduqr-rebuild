{
    "name": "bmdersleri/eduqr",
    "description": "QR-Based Interactive Classroom Polling Platform",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "endroid/qr-code": "^5.0",
        "phpmailer/phpmailer": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "EduQR\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload-dev": {
        "psr-4": {
            "EduQR\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
